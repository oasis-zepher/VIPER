# ============================================================
#  VIPER Agent — Environment Variables
#  Copy this file to `.env` and fill in your API keys.
# ============================================================

# ---------- LLM Provider ----------
# 填入你使用的提供商对应的 Key，其余留空即可

# Google Gemini（推荐，超长上下文 + 多模态）
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI（GPT-4.1 / o3 系列）
OPENAI_API_KEY=

# Anthropic Claude（需 pip install langchain-anthropic）
ANTHROPIC_API_KEY=

# DeepSeek（V3 / R1 推理）
DEEPSEEK_API_KEY=

# 通义千问 Qwen（DashScope 阿里云）
DASHSCOPE_API_KEY=

# Kimi Moonshot
MOONSHOT_API_KEY=

# 智谱 GLM
ZHIPU_API_KEY=

# ---------- Model Selection ----------
# 可选值示例:
#   google:    gemini-2.5-pro / gemini-2.5-flash / gemini-2.0-flash
#   openai:    gpt-4.1 / gpt-4.1-mini / gpt-4o / o3 / o4-mini
#   anthropic: claude-opus-4-5 / claude-sonnet-4-5 / claude-3-7-sonnet-20250219
#   deepseek:  deepseek-chat / deepseek-reasoner
#   qwen:      qwen-max / qwen-plus / qwen-turbo / qwen3-235b-a22b
#   moonshot:  moonshot-v1-128k / moonshot-v1-32k
#   zhipu:     glm-4-plus / glm-4-flash / glm-4v-plus / glm-z1-plus
DEFAULT_MODEL=gemini-2.5-flash

# Provider 强制覆盖（留空则自动从 DEFAULT_MODEL 推断）
# 可选: google / openai / anthropic / deepseek / qwen / moonshot / zhipu
LLM_PROVIDER=

# ---------- Project Defaults ----------
DEFAULT_PROJECT_ROOT=./projects

# ---------- UI ----------
STREAMLIT_PORT=8501

# ---------- UI ----------
STREAMLIT_PORT=8501
UI_LANGUAGE=zh-CN
