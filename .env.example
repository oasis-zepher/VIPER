# ============================================================
#  VIPER Agent — Environment Variables
#  Copy this file to `.env` and fill in your API keys.
# ============================================================

# ---------- LLM Provider (选择一个即可) ----------
# Gemini（默认推荐，超长上下文窗口，适合全量生信日志 & PDF）
GOOGLE_API_KEY=your_gemini_api_key_here

# OpenAI（可选备用）
OPENAI_API_KEY=

# ---------- Model Selection ----------
# gemini-2.0-flash / gemini-2.0-pro / gpt-4o / gpt-4o-mini
DEFAULT_MODEL=gemini-2.0-flash

# ---------- Project Defaults ----------
# 默认项目存储根目录（推荐 Google Drive 挂载路径）
# Windows 示例:  G:/My Drive/VIPER_Projects
# macOS 示例:    ~/Google Drive/My Drive/VIPER_Projects
DEFAULT_PROJECT_ROOT=./projects

# ---------- Execution ----------
# Conda 环境名（用于一键执行命令）
CONDA_ENV_NAME=viper

# SSH 远程主机（可选，用于 Remote-SSH 场景）
SSH_HOST=
SSH_USER=
SSH_KEY_PATH=

# ---------- UI ----------
STREAMLIT_PORT=8501
UI_LANGUAGE=zh-CN
